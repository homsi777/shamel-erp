# LAN host profile for local-network pilot use
# Copy to `.env.lan.local` and adjust values for the real host machine.

NODE_ENV=production
DB_DIALECT=postgres
DATABASE_URL=postgresql://postgres:12345678@127.0.0.1:5432/shamel_erp_pg

# Strong secret required for LAN operator use
JWT_SECRET=REPLACE_WITH_A_REAL_64_CHAR_RANDOM_STRING

# Bind API on all LAN interfaces
SERVER_HOST=0.0.0.0
SERVER_PORT=3111

# Host-facing URLs used in logs, readiness, and frontend build-time defaults
APP_BASE_URL=http://192.168.1.104:3111
PUBLIC_BASE_URL=http://192.168.1.104:3111
VITE_API_BASE_URL=http://192.168.1.104:3111/api

# Keep QR/public menu on the same port unless a separate LAN port is intentionally used
QR_MENU_PORT=3111
VITE_QR_MENU_PORT=3111

# Restrict browser cross-origin access to known local origins
CORS_ALLOWED_ORIGINS=http://192.168.1.104:3111,http://localhost:5173,http://127.0.0.1:5173

# Optional: explicit PostgreSQL tool path if not available on PATH
PG_BIN_DIR=C:\Program Files\PostgreSQL\16\bin

# Optional: backup output directory override
# PG_BACKUP_DIR=C:\ShamelERP\pg-backups
