# Shamel ERP — Production Environment Variables
# ================================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.

# ── Required ──────────────────────────────────────────────────────
NODE_ENV=production

# REQUIRED in production — minimum 32 characters, randomly generated
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_REAL_64_CHAR_RANDOM_STRING_NEVER_COMMIT_THIS

# ── Recommended ───────────────────────────────────────────────────
# Absolute path to the SQLite database file
# Default (if not set): <cwd>/data/shamel.db
# SHAMEL_DB_PATH=/opt/shamel/data/shamel.db

# Server port (default: 3000)
# PORT=3000

# ── Optional: Activation Notifications ───────────────────────────
# Telegram bot token and chat ID for activation audit notifications
# Leave blank to skip Telegram notifications (activation still works)
# ACTIVATION_NOTIFY_BOT_TOKEN=
# ACTIVATION_NOTIFY_CHAT_ID=
# ACTIVATION_CONNECTIVITY_URL=https://api.telegram.org

# ── Notes ─────────────────────────────────────────────────────────
# ERP_STRICT_MODE is automatically set to true when NODE_ENV=production
# Do not set it manually unless you need strict mode in development.
